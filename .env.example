# =============================================================================
# Agent Helper — CRM Adapter Configuration Template
# =============================================================================
# Copy this file to ".env" and fill in your real credentials.
# NEVER commit the real ".env" file to version control.
# =============================================================================

# --- CRM / External API Settings ---

# Base URL of your CRM REST API (no trailing slash)
CRM_BASE_URL=https://api.your-crm-provider.com/v1

# API Key or Bearer Token issued by your CRM provider
CRM_API_KEY=your_api_key_here

# Optional: timeout in seconds for API requests
CRM_TIMEOUT_SECONDS=10

# Optional: environment flag (development | staging | production)
CRM_ENVIRONMENT=development
